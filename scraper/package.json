{
  "name": "repair-ai-scraper",
  "version": "1.0.0",
  "description": "AI-powered web scraper for enriching RepairAi-files with repair documentation",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "repair-ai-scraper": "./src/index.js"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "scrape": "node src/index.js scrape",
    "analyze": "node src/index.js analyze-images",
    "update-sources": "node src/index.js update-sources",
    "integrate": "node src/index.js integrate",
    "index": "node src/index.js index"
  },
  "keywords": [
    "repair",
    "scraper",
    "ai",
    "repairai",
    "mobile-repair",
    "puppeteer"
  ],
  "author": "RepairAi Team",
  "license": "MIT",
  "dependencies": {
    "puppeteer": "^21.6.0",
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.3.1",
    "commander": "^11.1.0",
    "js-yaml": "^4.1.0",
    "sharp": "^0.33.1",
    "pdf-parse": "^1.1.1",
    "gray-matter": "^4.0.3",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
